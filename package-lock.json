import { sanitizeInput } from '../utils/security';

describe('Security Utilities', () => {
  it('strips HTML tags from input', () => {
    const maliciousInput = '<script>alert("xss")</script>Hello World';
    expect(sanitizeInput(maliciousInput)).toBe('alert("xss")Hello World'); 
    // note: the regex `<[^>]*>?/gm` strips `<script>` and `</script>` leaving pure text.
  });

  it('enforces a maximum length of 200 characters', () => {
    const longString = 'a'.repeat(300);
    expect(sanitizeInput(longString).length).toBe(200);
  });

  it('trims whitespace', () => {
    expect(sanitizeInput('   hello   ')).toBe('hello');
  });

  it('returns empty string for non-string inputs', () => {
    expect(sanitizeInput(null)).toBe('');
    expect(sanitizeInput(123)).toBe('');
  });
});
